<section class="faq-section" id="faq">
  <div class="section-inner">
    <div class="section-head-center reveal">
      <p class="section-label">Dúvidas</p>
      <h2 class="section-title section-title--narrow">Respostas antes<br>de você perguntar</h2>
    </div>
    <div class="faq-list">
      {% set td = lavacash.trialDays | string %}
      {% if not lavacash.refund.moneyBackAfterPaidSubscription %}
        {% set refundExtra = " Não há reembolso em dinheiro automático após a cobrança da mensalidade; você controla a renovação." %}
      {% else %}
        {% set refundExtra = "" %}
      {% endif %}
      {% for item in faq %}
      <details class="faq-item">
        <summary class="faq-q">{{ item.question | replace("__TRIAL_DAYS__", td) }}<span class="faq-arrow" aria-hidden="true">+</span></summary>
        <div class="faq-a">
          {% set raw = item.answerHtml
            | replace("__TRIAL_DAYS__", td)
            | replace("__REFUND_EXTRA__", refundExtra)
            | replace("__IOS_ROADMAP__", lavacash.ios.roadmap) %}
          {{ raw | safe }}
        </div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>

<section class="lead-section" id="dicas" aria-labelledby="lead-heading">
  <div class="section-inner lead-inner">
    <div class="lead-copy reveal">
      <p class="section-label">Fique por dentro</p>
      <h2 id="lead-heading" class="section-title">{{ lavacash.leadMagnet.sectionTitle }}</h2>
      <p class="section-desc">{{ lavacash.leadMagnet.sectionDesc }}</p>
    </div>
    <form class="lead-form reveal reveal-delay-1" name="lead-lavacash" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/">
      <input type="hidden" name="form-name" value="lead-lavacash">
      <p class="lead-honeypot">
        <label>Não preencha: <input name="bot-field" autocomplete="off" tabindex="-1"></label>
      </p>
      <div class="lead-fields">
        <label class="lead-label" for="lead-email">Seu melhor e-mail</label>
        <input class="lead-input" id="lead-email" name="email" type="email" autocomplete="email" required placeholder="voce@empresa.com.br">
        <button class="lead-submit" type="submit">{{ lavacash.leadMagnet.buttonLabel }}</button>
      </div>
      <p class="lead-disclaimer">Ao enviar, você concorda em receber e-mails conforme nossa <a href="/privacidade/">política de privacidade</a>.</p>
    </form>
  </div>
</section>

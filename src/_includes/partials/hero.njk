<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-bg" aria-hidden="true"></div>
  <p class="hero-badge">{{ lavacash.trialDays }} dias grátis · Sem cartão de crédito · Android · <span class="hero-badge-muted">{{ lavacash.ios.badge }}</span></p>
  <h1 id="hero-heading">Controle seu lava-jato<br>em <em>segundos,</em> não em folhas soltas.</h1>
  <p class="hero-sub">{% if lavacash.launchOffer.active %}Veja lucro e atendimentos com clareza, organize clientes e pare de fechar o dia no chute — a partir de <strong>R${{ lavacash.launchOffer.formatted }}/mês</strong> na oferta atual.{% else %}Veja lucro e atendimentos com clareza, organize clientes e pare de fechar o dia no chute — direto no celular por R${{ lavacash.priceMonthly.formatted }}/mês.{% endif %}</p>
  <div class="hero-ctas">
    <a href="{% if lavacash.android.apkUrl %}{{ lavacash.android.apkUrl }}{% else %}#comecar{% endif %}" class="btn-primary"{% if lavacash.android.apkUrl %} target="_blank" rel="noopener noreferrer"{% endif %}>
      {{ lavacash.android.trialCtaLabel }}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </a>
    <a href="#demos" class="btn-secondary">Ver como funciona</a>
  </div>
  <p class="hero-cta-hint">Leva menos de 2 minutos para começar o teste.</p>
  <div class="hero-micro">
    <span>Sem cartão</span>
    <span>Sem fidelidade</span>
    <span>Suporte no WhatsApp</span>
  </div>
  <div class="hero-video">
    <div class="hero-video-frame">
      <video autoplay muted loop playsinline preload="metadata">
        <source src="/videos/video-visaogeralapp.mp4" type="video/mp4">
      </video>
    </div>
  </div>
</section>
